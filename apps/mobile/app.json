{
  "expo": {
    "name": "FinTrack",
    "slug": "fintrack",
    "scheme": "fintrack",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "plugins": ["expo-router", "expo-secure-store", "expo-sqlite"],
    "experiments": {
      "typedRoutes": true
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#07090D"
      }
    }
  }
}
